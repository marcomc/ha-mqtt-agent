# Copy this file to ~/.config/ha-mqtt-agent/config.toml or pass it with
# --config.

mqtt_host = "mqtt.example.local"
mqtt_port = 1883
# mqtt_username = "homeassistant"
# mqtt_password = "change-me"

mqtt_client_id = "ha-mqtt-agent"
discovery_prefix = "homeassistant"
topic_prefix = "ha_mqtt_agent"

device_id = "host"
device_name = "Host"

sample_interval_seconds = 5
# Minimum supported publish interval is 1 second.
expire_after_seconds = 15
max_energy_gap_seconds = 300
state_path = "~/.local/state/ha-mqtt-agent/state.json"
publish_retain = true
verbose = false
