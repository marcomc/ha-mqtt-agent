{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Home Assistant MQTT Agent config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mqtt_host": {
      "type": "string",
      "default": "mqtt.example.local"
    },
    "mqtt_port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "default": 1883
    },
    "mqtt_username": {
      "type": "string"
    },
    "mqtt_password": {
      "type": "string"
    },
    "mqtt_client_id": {
      "type": "string",
      "default": "ha-mqtt-agent"
    },
    "discovery_prefix": {
      "type": "string",
      "default": "homeassistant"
    },
    "topic_prefix": {
      "type": "string",
      "default": "ha_mqtt_agent"
    },
    "device_id": {
      "type": "string",
      "default": "host"
    },
    "device_name": {
      "type": "string",
      "default": "Host"
    },
    "sample_interval_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 5
    },
    "expire_after_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 15
    },
    "max_energy_gap_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 300
    },
    "state_path": {
      "type": "string",
      "default": "~/.local/state/ha-mqtt-agent/state.json"
    },
    "publish_retain": {
      "type": "boolean",
      "default": true
    },
    "verbose": {
      "type": "boolean",
      "default": false
    }
  }
}
