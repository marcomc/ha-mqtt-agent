{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Home Assistant MQTT Agent config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mqtt_host": {
      "type": "string",
      "default": "mqtt.example.local"
    },
    "mqtt_port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "default": 1883
    },
    "mqtt_username": {
      "type": "string"
    },
    "mqtt_password": {
      "type": "string"
    },
    "mqtt_client_id": {
      "type": "string",
      "default": "ha-mqtt-agent"
    },
    "discovery_prefix": {
      "type": "string",
      "default": "homeassistant"
    },
    "topic_prefix": {
      "type": "string",
      "default": "ha_mqtt_agent"
    },
    "device_id": {
      "type": "string",
      "default": "host"
    },
    "device_name": {
      "type": "string",
      "default": "Host"
    },
    "sample_interval_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 5
    },
    "expire_after_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 15
    },
    "max_energy_gap_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 300
    },
    "network_interval_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 60
    },
    "ping_timeout_seconds": {
      "type": "number",
      "minimum": 0.1,
      "default": 1
    },
    "ping_targets": {
      "type": "array",
      "default": [
        {
          "id": "cloudflare_dns",
          "host": "1.1.1.1",
          "name": "Cloudflare DNS"
        },
        {
          "id": "cloudflare_dns_secondary",
          "host": "1.0.0.1",
          "name": "Cloudflare DNS secondary"
        },
        {
          "id": "google_dns",
          "host": "8.8.8.8",
          "name": "Google DNS"
        },
        {
          "id": "google_dns_secondary",
          "host": "8.8.4.4",
          "name": "Google DNS secondary"
        }
      ],
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "host"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "host": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    "wifi_helper_path": {
      "type": "string",
      "default": "~/.local/share/ha-mqtt-agent/HaMqttAgentWifiHelper.app/Contents/MacOS/HaMqttAgentWifiHelper"
    },
    "state_path": {
      "type": "string",
      "default": "~/.local/state/ha-mqtt-agent/state.json"
    },
    "publish_retain": {
      "type": "boolean",
      "default": true
    },
    "verbose": {
      "type": "boolean",
      "default": false
    }
  }
}
